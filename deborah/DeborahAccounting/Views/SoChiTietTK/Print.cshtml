@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Sổ chi tiết tài khoản</title>
    <style>
        body { font-family: 'Times New Roman', serif; font-size: 12px; margin: 20px 40px; color: #000; }
        .header { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .header-left { width: 55%; font-size: 12px; }
        .header-right { width: 40%; text-align: right; font-size: 11px; font-style: italic; }
        h2 { text-align: center; font-size: 18px; margin: 12px 0 5px; letter-spacing: 3px; font-weight: bold; }
        .info-center { text-align: center; font-size: 12px; margin-bottom: 2px; }
        table.ct { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 11px; }
        table.ct th, table.ct td { border: 1px solid #000; padding: 3px 5px; }
        table.ct th { background: #f0f0f0; text-align: center; font-weight: bold; }
        table.ct td.num { text-align: right; }
        .tdk td { font-weight: 600; }
        .total-row td { font-weight: bold; }
        .sign-section { display: flex; justify-content: space-between; margin-top: 25px; text-align: center; font-size: 12px; }
        .sign-section div { width: 30%; }
        .sign-section .title { font-weight: bold; }
        .sign-section .sub { font-style: italic; font-size: 11px; }
        .sign-section .name { margin-top: 50px; font-weight: bold; }
        .date-line { text-align: right; font-style: italic; font-size: 12px; margin-top: 12px; }
        @@media print { body { margin: 10px 25px; } }
    </style>
</head>
<body>
    <div id="printContent"></div>
    <script>
        var data = null;
        try { data = JSON.parse(localStorage.getItem('scttkPrintData')); } catch(e) {}
        if (!data) { document.body.innerHTML = '<p>Không có dữ liệu để in.</p>'; }
        else { renderPrint(data); window.print(); }

        function renderPrint(d) {
            var h = '';
            h += '<div class="header"><div class="header-left"><b>CÔNG TY CỔ PHẦN DEBORAH (DEBORAH HOME)</b><br/>';
            h += 'Số 113 Điện Biên, Phường Cửa Bắc, Thành phố Nam Định, Tỉnh Nam Định<br/>Mã số thuế: 0601164235<br/>Điện thoại: 0363831464</div>';
            h += '<div class="header-right"><b>Mẫu số: S03b - DN</b><br/><i>Ban hành kèm theo Thông tư số<br/>200/2014/TT-BTC ngày<br/>22/12/2014 của Bộ Tài chính</i></div></div>';

            h += '<h2>SỔ CHI TIẾT TÀI KHOẢN</h2>';
            h += '<div class="info-center">Từ ngày <b>' + d.tuNgay + '</b> &nbsp;&nbsp;&nbsp; đến ngày <b>' + d.denNgay + '</b></div>';
            h += '<div class="info-center">Tài Khoản: <b>' + d.maTK + ' - ' + d.tenTK + '</b></div>';

            h += '<table class="ct"><thead>';
            h += '<tr><th rowspan="2" style="width:75px">Ngày<br/>tháng<br/>ghi sổ</th>';
            h += '<th colspan="2">Chứng từ</th><th rowspan="2">Diễn giải</th>';
            h += '<th rowspan="2">Số hiệu<br/>TK đối<br/>ứng</th>';
            h += '<th colspan="3">Số tiền</th></tr>';
            h += '<tr><th>Số hiệu</th><th>Ngày,<br/>tháng</th>';
            h += '<th>Nợ</th><th>Có</th><th>Tồn</th></tr>';
            h += '<tr style="font-weight:bold;text-align:center"><td>A</td><td>B</td><td>C</td><td>D</td><td>E</td><td>1</td><td>2</td><td>3</td></tr>';
            h += '</thead><tbody>';

            h += '<tr class="tdk"><td></td><td></td><td></td><td>Số dư đầu kỳ</td><td></td>';
            h += '<td class="num">' + (d.duNoDauKy ? fmt(d.duNoDauKy) : '0') + '</td>';
            h += '<td class="num">' + (d.duCoDauKy ? fmt(d.duCoDauKy) : '0') + '</td>';
            h += '<td class="num">' + fmt(d.duDauKy) + '</td></tr>';

            d.rows.forEach(function(r) {
                h += '<tr><td>' + r.ngayCT + '</td><td>' + r.soCT + '</td><td>' + r.ngayCT + '</td>';
                h += '<td>' + r.lyDo + '</td>';
                h += '<td style="text-align:center">' + r.tkDoiUng + '</td>';
                h += '<td class="num">' + (r.no ? fmt(r.no) : '0') + '</td>';
                h += '<td class="num">' + (r.co ? fmt(r.co) : '0') + '</td>';
                h += '<td class="num">' + fmt(r.ton) + '</td></tr>';
            });

            h += '<tr class="total-row"><td colspan="5" style="text-align:center">Tổng Phát Sinh</td>';
            h += '<td class="num">' + fmt(d.tongNo) + '</td><td class="num">' + fmt(d.tongCo) + '</td><td class="num">0</td></tr>';
            h += '<tr class="tdk"><td colspan="5" style="text-align:center">Số dư cuối kỳ</td>';
            h += '<td class="num">' + fmt(d.duNoCuoi) + '</td><td class="num">' + fmt(d.duCoCuoi) + '</td><td class="num">0</td></tr>';
            h += '</tbody></table>';

            h += '<div class="date-line">Ngày.....tháng.....năm.....</div>';
            h += '<div class="sign-section">';
            h += '<div><span class="title">Người lập</span><br/><span class="sub">(Ký, họ tên)</span><br/><span class="name"></span></div>';
            h += '<div><span class="title">Kế toán trưởng</span><br/><span class="sub">(Ký, họ tên)</span><br/><span class="name">Đặng Thị Yến</span></div>';
            h += '<div><span class="title">Giám đốc</span><br/><span class="sub">(Ký, họ tên, đóng dấu)</span><br/><span class="name">WANG YONGFENG</span></div>';
            h += '</div>';
            document.getElementById('printContent').innerHTML = h;
        }
        function fmt(n) { return n != null ? n.toLocaleString('vi-VN') : ''; }
    </script>
</body>
</html>
