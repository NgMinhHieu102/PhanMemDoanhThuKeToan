@model DeborahAccounting.Models.HDHH
@{ Layout = null; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><title>Hóa đơn GTGT - @Model.SoHD</title>
<style>
body{font-family:'Times New Roman',serif;font-size:13px;margin:30px 50px;color:#000}
.header-left{font-size:12px;margin-bottom:10px}
h2{text-align:center;font-size:20px;margin:10px 0 5px;letter-spacing:3px;font-weight:bold;color:red}
.info-line{font-size:13px;margin-bottom:2px}
table.ct{width:100%;border-collapse:collapse;margin-top:10px;font-size:12px}
table.ct th,table.ct td{border:1px solid #000;padding:4px 6px}
table.ct th{text-align:center;font-weight:bold}
table.ct td.num{text-align:right}
.total-section{margin-top:5px;font-size:13px}
.total-section .row{display:flex;justify-content:flex-end;gap:20px;margin-bottom:2px}
.sign-section{display:flex;justify-content:space-between;margin-top:30px;text-align:center;font-size:12px}
.sign-section div{width:30%}.sign-section .title{font-weight:bold}.sign-section .sub{font-style:italic;font-size:11px}
@@media print{body{margin:15px 30px}}
</style></head>
<body onload="window.print()">
<div class="header-left">
    <b style="color:red">Công ty Cổ phần Deborah (Deborah Home)</b><br/>
    <i>Địa chỉ: Số 113 Điện Biên, Phường Cửa Bắc, Thành phố Nam Định, Tỉnh Nam Định</i><br/>
    Mã số thuế: 0601164235<br/>Điện thoại: 0363831464
</div>
<h2>HÓA ĐƠN GIÁ TRỊ GIA TĂNG</h2>
<div style="text-align:center;font-size:13px">@Model.NgayHD.ToString("dd/MM/yyyy")
    <span style="float:right;font-size:11px">Mẫu số: 01GTKT3/001<br/>Ký hiệu: AA/14P<br/>Số HD: @Model.SoHD</span>
</div>
<div class="info-line">Họ tên người mua hàng: <b>@Model.KhachHang?.TenKH</b></div>
<div class="info-line">Địa chỉ: @Model.KhachHang?.DiaChi</div>
<div class="info-line">Hình thức thanh toán: @Model.HTTT</div>
<div class="info-line">Mã số thuế: @Model.KhachHang?.MaSoThue</div>

<table class="ct">
    <thead><tr><th>Tên hàng hóa</th><th>Đvt</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
    <tbody>
    @{ decimal tong = 0; }
    @foreach(var ct in Model.ChiTietHoaDon)
    {
        var tt = ct.SoLuong * ct.DonGia; tong += tt;
        <tr><td>@ct.HangHoa?.TenHH</td><td>@ct.HangHoa?.Dvt</td>
        <td class="num">@ct.SoLuong.ToString("N2")</td><td class="num">@ct.DonGia.ToString("N2")</td>
        <td class="num">@tt.ToString("N2")</td></tr>
    }
    </tbody>
</table>
<div class="total-section">
    <div class="row"><span>Cộng tiền hàng:</span><b>@tong.ToString("N2") VND</b></div>
    <div class="row"><span>Thuế suất GTGT:@Model.ThueSuat.ToString("N2") %</span><span>Tiền thuế GTGT:</span><b>@Model.TienThue.ToString("N2") VND</b></div>
    <div class="row"><span>Tổng cộng tiền thanh toán:</span><b>@Model.TienThanhToan.ToString("N2") VND</b></div>
</div>
<div class="sign-section">
    <div><span class="title">Người mua hàng</span><br/><span class="sub">(Ký và ghi rõ họ tên)</span></div>
    <div><span class="title">Người bán hàng</span><br/><span class="sub">(Ký và ghi rõ họ tên)</span></div>
    <div><span class="title">Thủ trưởng đơn vị</span><br/><span class="sub">(Ký và ghi rõ họ tên)</span></div>
</div>
</body></html>
