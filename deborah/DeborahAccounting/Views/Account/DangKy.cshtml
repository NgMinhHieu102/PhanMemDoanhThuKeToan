@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Deborah Accounting</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            margin: 0; padding: 0; min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80') center/cover no-repeat;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body::before {
            content: ''; position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 30, 80, 0.55); z-index: 0;
        }
        .reg-container {
            position: relative; z-index: 1; width: 560px;
            background: linear-gradient(135deg, rgba(200,220,255,0.92), rgba(180,210,255,0.88));
            border-radius: 10px; overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.3);
        }
        .reg-title {
            text-align: center; padding: 25px 20px 15px;
        }
        .reg-title h2 {
            color: #003399; font-weight: 900; font-size: 26px;
            text-transform: uppercase; letter-spacing: 3px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1); margin: 0;
        }
        .reg-body { padding: 10px 40px 30px; }
        .form-row {
            display: flex; align-items: center; margin-bottom: 18px;
        }
        .form-row label {
            width: 170px; font-weight: 600; color: #003366;
            font-size: 15px; flex-shrink: 0;
        }
        .form-row input, .form-row select {
            flex: 1; padding: 8px 12px; border: 1px solid #99b3cc;
            border-radius: 4px; font-size: 15px; background: white;
        }
        .form-row input:focus, .form-row select:focus {
            outline: none; border-color: #3366cc;
            box-shadow: 0 0 5px rgba(51,102,204,0.3);
        }
        .btn-group-reg {
            display: flex; justify-content: center; gap: 30px; margin-top: 25px;
        }
        .btn-reg {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 24px; border: 1px solid #aaa; border-radius: 5px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            background: linear-gradient(to bottom, #f8f8f8, #e0e0e0);
            color: #333; transition: all 0.2s; text-decoration: none;
        }
        .btn-reg:hover {
            background: linear-gradient(to bottom, #fff, #eee);
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }
        .btn-reg i { font-size: 18px; }
        .btn-reg.submit i { color: #28a745; }
        .btn-reg.cancel i { color: #cc3333; }
        .error-msg { text-align: center; color: #cc0000; font-size: 14px; margin-bottom: 10px; }
        .success-msg { text-align: center; color: #28a745; font-size: 14px; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="reg-container">
        <div class="reg-title">
            <h2>Đăng ký</h2>
        </div>
        <div class="reg-body">
            <div id="msgError" class="error-msg" style="display:none"></div>
            <div id="msgSuccess" class="success-msg" style="display:none"></div>

            <div class="form-row">
                <label>Tên đăng nhập</label>
                <input id="fTenDN" maxlength="50" />
            </div>
            <div class="form-row">
                <label>Mật khẩu</label>
                <input id="fMatKhau" type="password" maxlength="20" />
            </div>
            <div class="form-row">
                <label>Xác nhận mật khẩu</label>
                <input id="fXacNhanMK" type="password" maxlength="20" />
            </div>
            <div class="form-row">
                <label>Tên đầy đủ</label>
                <input id="fTenNguoiDung" maxlength="60" />
            </div>
            <div class="form-row">
                <label>Quyền</label>
                <select id="fQuyen">
                    <option value="1">Admin</option>
                    <option value="2">Kế toán</option>
                </select>
            </div>

            <div class="btn-group-reg">
                <button class="btn-reg submit" onclick="dangKy()">
                    <i class="bi bi-check-square-fill"></i> Đăng ký
                </button>
                <a href="/" class="btn-reg cancel">
                    <i class="bi bi-x-circle-fill"></i> Thoát
                </a>
            </div>
        </div>
    </div>

    <script>
    function dangKy() {
        let tenDN = document.getElementById('fTenDN').value.trim();
        let mk = document.getElementById('fMatKhau').value;
        let xnmk = document.getElementById('fXacNhanMK').value;
        let tenND = document.getElementById('fTenNguoiDung').value;
        let quyen = parseInt(document.getElementById('fQuyen').value);

        document.getElementById('msgError').style.display = 'none';
        document.getElementById('msgSuccess').style.display = 'none';

        if (!tenDN) { showError('Vui lòng nhập tên đăng nhập'); return; }
        if (!mk) { showError('Vui lòng nhập mật khẩu'); return; }
        if (mk !== xnmk) { showError('Mật khẩu xác nhận không khớp!'); return; }

        fetch('/NguoiDung/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ TenDN: tenDN, MatKhau: mk, TenNguoiDung: tenND, Quyen: quyen })
        })
        .then(r => r.json())
        .then(r => {
            if (r.success) {
                document.getElementById('msgSuccess').textContent = 'Đăng ký thành công!';
                document.getElementById('msgSuccess').style.display = 'block';
                ['fTenDN','fMatKhau','fXacNhanMK','fTenNguoiDung'].forEach(id => document.getElementById(id).value = '');
            } else showError(r.message);
        });
    }
    function showError(msg) {
        document.getElementById('msgError').textContent = msg;
        document.getElementById('msgError').style.display = 'block';
    }
    </script>
</body>
</html>
