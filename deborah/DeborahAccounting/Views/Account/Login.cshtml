@model DeborahAccounting.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - Deborah Accounting</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80') center/cover no-repeat;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 30, 80, 0.55);
            z-index: 0;
        }
        .login-container {
            position: relative;
            z-index: 1;
            width: 520px;
            background: linear-gradient(135deg, rgba(200,220,255,0.92), rgba(180,210,255,0.88));
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.3);
        }
        .login-title {
            text-align: center;
            padding: 25px 20px 15px;
        }
        .login-title h2 {
            color: #003399;
            font-weight: 900;
            font-size: 26px;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
            margin: 0;
        }
        .login-body {
            padding: 10px 40px 30px;
        }
        .form-row {
            display: flex;
            align-items: center;
            margin-bottom: 18px;
        }
        .form-row label {
            width: 140px;
            font-weight: 600;
            color: #003366;
            font-size: 15px;
            flex-shrink: 0;
        }
        .form-row label .required {
            color: red;
            font-size: 12px;
            vertical-align: super;
            margin-left: 2px;
        }
        .form-row input {
            flex: 1;
            padding: 8px 12px;
            border: 1px solid #99b3cc;
            border-radius: 4px;
            font-size: 15px;
            background: white;
        }
        .form-row input:focus {
            outline: none;
            border-color: #3366cc;
            box-shadow: 0 0 5px rgba(51,102,204,0.3);
        }
        .btn-group-login {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 25px;
        }
        .btn-login {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 24px;
            border: 1px solid #aaa;
            border-radius: 5px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            background: linear-gradient(to bottom, #f8f8f8, #e0e0e0);
            color: #333;
            transition: all 0.2s;
        }
        .btn-login:hover {
            background: linear-gradient(to bottom, #fff, #eee);
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }
        .btn-login i { font-size: 18px; }
        .btn-login.cancel i { color: #cc3333; }
        .btn-login.submit i { color: #336699; }
        .error-msg {
            text-align: center;
            color: #cc0000;
            font-size: 14px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-title">
            <h2>Đăng nhập hệ thống</h2>
        </div>
        <div class="login-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="error-msg"></div>

                <div class="form-row">
                    <label>Tên đăng nhập: <span class="required">*</span></label>
                    <input asp-for="Username" placeholder="" autofocus />
                </div>

                <div class="form-row">
                    <label>Mật khẩu: <span class="required">*</span></label>
                    <input asp-for="Password" placeholder="" />
                </div>

                <div class="btn-group-login">
                    <button type="submit" class="btn-login submit">
                        <i class="bi bi-person-check"></i> Đăng nhập
                    </button>
                    <a href="javascript:window.close();" class="btn-login cancel" style="text-decoration:none;">
                        <i class="bi bi-x-circle-fill"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
