@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Thẻ kho</title>
    <style>
        body { font-family: 'Times New Roman', serif; font-size: 13px; margin: 30px 50px; color: #000; }
        .header { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .header-left { width: 55%; font-size: 12px; }
        .header-right { width: 40%; text-align: right; font-size: 11px; font-style: italic; }
        h2 { text-align: center; font-size: 20px; margin: 15px 0 5px; letter-spacing: 5px; font-weight: bold; }
        .info-center { text-align: center; font-size: 13px; margin-bottom: 3px; }
        table.ct { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 12px; }
        table.ct th, table.ct td { border: 1px solid #000; padding: 4px 6px; }
        table.ct th { background: #f0f0f0; text-align: center; font-weight: bold; }
        table.ct td.num { text-align: right; }
        .tdk td { font-weight: 600; }
        .total-row td { font-weight: bold; }
        .sign-section { display: flex; justify-content: space-between; margin-top: 30px; text-align: center; font-size: 12px; }
        .sign-section div { width: 30%; }
        .sign-section .title { font-weight: bold; }
        .sign-section .sub { font-style: italic; font-size: 11px; }
        .sign-section .name { margin-top: 50px; font-weight: bold; }
        .date-line { text-align: right; font-style: italic; font-size: 12px; margin-top: 15px; }
        @@media print { body { margin: 15px 30px; } }
    </style>
</head>
<body>
    <div id="printContent"></div>
    <script>
        var data = null;
        try { data = JSON.parse(localStorage.getItem('theKhoPrintData')); } catch(e) {}
        if (!data) { document.body.innerHTML = '<p>Không có dữ liệu để in.</p>'; }
        else { renderPrint(data); window.print(); }

        function renderPrint(d) {
            var html = '';
            html += '<div class="header">';
            html += '<div class="header-left"><b>Công ty TNHH Cơ khí Chính xác RUIYOU Việt Nam</b><br/>';
            html += 'Lô 15 Cụm công nghiệp Nội Hoàng, Xã Nội Hoàng, Huyện Yên Dũng, Tỉnh<br/>Bắc Giang, Việt Nam<br/>2400866968</div>';
            html += '<div class="header-right"><b>Mẫu số S10- DN</b><br/>';
            html += '<i>Ban hành kèm theo Thông tư số<br/>200/2014/TT-BTC ngày<br/>22/12/2014 của Bộ Tài chính</i></div>';
            html += '</div>';

            html += '<h2>THẺ KHO</h2>';
            html += '<div class="info-center">Từ ngày <b>' + d.tuNgay + '</b> &nbsp;&nbsp;&nbsp; đến ngày <b>' + d.denNgay + '</b></div>';
            html += '<div class="info-center">Kho: <b>' + d.maKho + ' - ' + d.tenKho + '</b></div>';
            html += '<div class="info-center">Vật tư: <b>' + d.maVT + ' - ' + d.tenVT + '</b></div>';

            html += '<table class="ct"><thead>';
            html += '<tr><th rowspan="2" style="width:90px">Ngày tháng<br/>ghi sổ</th>';
            html += '<th colspan="2">Chứng từ</th>';
            html += '<th rowspan="2">Diễn giải</th>';
            html += '<th colspan="3">Số lượng</th></tr>';
            html += '<tr><th>Số hiệu</th><th>Ngày,<br/>tháng</th>';
            html += '<th>SL Nhập</th><th>SL Xuất</th><th>SL Tồn</th></tr>';
            html += '</thead><tbody>';

            // Tồn đầu kỳ
            html += '<tr class="tdk"><td></td><td></td><td></td><td>Tồn đầu kỳ</td>';
            html += '<td class="num">0</td><td class="num">0</td>';
            html += '<td class="num">' + fmt(d.tonDauKy) + '</td></tr>';

            var tN = 0, tX = 0;
            d.rows.forEach(function(r) {
                tN += r.nhap; tX += r.xuat;
                html += '<tr>';
                html += '<td>' + r.ngayCT + '</td>';
                html += '<td>' + r.soCT + '</td>';
                html += '<td>' + r.ngayCT + '</td>';
                html += '<td>' + r.lyDo + '</td>';
                html += '<td class="num">' + (r.nhap ? fmt(r.nhap) : '0') + '</td>';
                html += '<td class="num">' + (r.xuat ? fmt(r.xuat) : '0') + '</td>';
                html += '<td class="num">' + fmt(r.ton) + '</td>';
                html += '</tr>';
            });

            var tc = d.rows.length > 0 ? d.rows[d.rows.length - 1].ton : d.tonDauKy;
            html += '<tr class="total-row"><td colspan="4" style="text-align:center">Tổng cộng</td>';
            html += '<td class="num">' + fmt(tN) + '</td>';
            html += '<td class="num">' + fmt(tX) + '</td>';
            html += '<td class="num">' + fmt(tc) + '</td></tr>';
            html += '</tbody></table>';

            html += '<div class="date-line">Ngày.....tháng.....năm.....</div>';

            html += '<div class="sign-section">';
            html += '<div><span class="title">Người lập</span><br/><span class="sub">(Ký, họ tên)</span><br/><span class="name"></span></div>';
            html += '<div><span class="title">Kế toán trưởng</span><br/><span class="sub">(Ký, họ tên)</span><br/><span class="name">Đặng Thị Yến</span></div>';
            html += '<div><span class="title">Giám đốc</span><br/><span class="sub">(Ký, họ tên, đóng dấu)</span><br/><span class="name">WANG YONGFENG</span></div>';
            html += '</div>';

            document.getElementById('printContent').innerHTML = html;
        }

        function fmt(n) { return n != null ? n.toLocaleString('vi-VN') : ''; }
    </script>
</body>
</html>
