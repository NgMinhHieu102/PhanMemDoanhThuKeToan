@model List<DeborahAccounting.Models.DMKH>
@{ ViewData["Title"] = "Danh mục khách hàng"; }
<link rel="stylesheet" href="~/css/danhmuc.css" />

<div class="dm-container">
    <div class="dm-toolbar">
        <button class="btn btn-add" onclick="showAdd()"><i class="bi bi-plus-circle"></i> Thêm</button>
        <button class="btn btn-edit" onclick="showEdit()"><i class="bi bi-pencil"></i> Sửa</button>
        <button class="btn btn-delete" onclick="doDelete()"><i class="bi bi-trash"></i> Xóa</button>
        <button class="btn btn-reload" onclick="reload()"><i class="bi bi-arrow-clockwise"></i> Tải lại dữ liệu</button>
        <button class="btn btn-print"><i class="bi bi-printer"></i> In</button>
        <a class="btn btn-close-form" asp-controller="Home" asp-action="Index"><i class="bi bi-x-circle-fill"></i> Thoát</a>
    </div>
    <div class="dm-table-wrap">
        <table class="dm-grid">
            <thead><tr><th style="width:24px"></th><th>Mã KH</th><th>Tên KH</th><th>Mã số thuế</th><th>Điện thoại</th><th>Địa chỉ</th><th>Email</th></tr></thead>
            <tbody id="gridBody">
                @foreach (var item in Model)
                {
                    <tr data-id="@item.MaKH" onclick="selectRow(this)">
                        <td class="row-indicator">▶</td>
                        <td>@item.MaKH</td><td>@item.TenKH</td><td>@item.MaSoThue</td>
                        <td>@item.DienThoai</td><td>@item.DiaChi</td><td>@item.Email</td>
                    </tr>
                }
                <tr class="new-row"><td class="row-indicator"><span class="required-star">✱</span></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade dm-modal" id="formModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Cập nhật danh mục KH</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editMode" />
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Mã KH</label>
                    <div class="col-sm-5"><input class="form-control" id="fMaKH" maxlength="10" /></div>
                </div>
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Tên KH</label>
                    <div class="col-sm-9"><input class="form-control" id="fTenKH" maxlength="128" /></div>
                </div>
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Địa chỉ</label>
                    <div class="col-sm-9"><input class="form-control" id="fDiaChi" maxlength="200" /></div>
                </div>
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Email</label>
                    <div class="col-sm-9"><input class="form-control" id="fEmail" maxlength="100" /></div>
                </div>
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Số ĐT</label>
                    <div class="col-sm-5"><input class="form-control" id="fDienThoai" maxlength="20" /></div>
                </div>
                <div class="mb-2 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-bold">Mã số thuế</label>
                    <div class="col-sm-5"><input class="form-control" id="fMaSoThue" maxlength="20" /></div>
                </div>
            </div>
            <div class="modal-footer justify-content-end gap-2">
                <button class="btn btn-primary" onclick="save()"><i class="bi bi-floppy"></i> Lưu</button>
                <button class="btn btn-danger" data-bs-dismiss="modal"><i class="bi bi-x-circle-fill"></i> Hủy</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let selectedId = null;
function selectRow(tr) { document.querySelectorAll('#gridBody tr').forEach(r => r.classList.remove('selected')); tr.classList.add('selected'); selectedId = tr.dataset.id; }
function showAdd() {
    document.getElementById('editMode').value = 'add';
    document.getElementById('modalTitle').textContent = 'Thêm khách hàng';
    ['fMaKH','fTenKH','fDiaChi','fEmail','fDienThoai','fMaSoThue'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('fMaKH').disabled = false;
    new bootstrap.Modal(document.getElementById('formModal')).show();
}
function showEdit() {
    if (!selectedId) { alert('Chọn một dòng để sửa'); return; }
    let tr = document.querySelector(`tr[data-id="${selectedId}"]`);
    document.getElementById('editMode').value = 'edit';
    document.getElementById('modalTitle').textContent = 'Cập nhật danh mục KH';
    document.getElementById('fMaKH').value = selectedId; document.getElementById('fMaKH').disabled = true;
    document.getElementById('fTenKH').value = tr.cells[2].textContent;
    document.getElementById('fMaSoThue').value = tr.cells[3].textContent;
    document.getElementById('fDienThoai').value = tr.cells[4].textContent;
    document.getElementById('fDiaChi').value = tr.cells[5].textContent;
    document.getElementById('fEmail').value = tr.cells[6].textContent;
    new bootstrap.Modal(document.getElementById('formModal')).show();
}
function save() {
    let mode = document.getElementById('editMode').value;
    let url = mode === 'add' ? '@Url.Action("Create")' : '@Url.Action("Edit")';
    let data = { MaKH: document.getElementById('fMaKH').value, TenKH: document.getElementById('fTenKH').value,
        DiaChi: document.getElementById('fDiaChi').value, Email: document.getElementById('fEmail').value,
        DienThoai: document.getElementById('fDienThoai').value, MaSoThue: document.getElementById('fMaSoThue').value };
    fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })
    .then(r => r.json()).then(r => { if (r.success) { bootstrap.Modal.getInstance(document.getElementById('formModal')).hide(); reload(); } else alert(r.message); });
}
function doDelete() {
    if (!selectedId) { alert('Chọn một dòng để xóa'); return; }
    if (!confirm('Xác nhận xóa?')) return;
    fetch('@Url.Action("Delete")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(selectedId) })
    .then(r => r.json()).then(r => { if (r.success) reload(); else alert(r.message); });
}
function reload() { location.reload(); }
</script>
}
