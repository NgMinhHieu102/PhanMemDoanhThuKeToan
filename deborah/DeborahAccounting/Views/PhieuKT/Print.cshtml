@model DeborahAccounting.Models.PhieuKT
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Phiếu Kế Toán - @Model.SoCT</title>
    <style>
        body { font-family: 'Times New Roman', serif; font-size: 13px; margin: 30px 50px; color: #000; }
        .header-left { font-size: 12px; margin-bottom: 15px; }
        h2 { text-align: center; font-size: 20px; margin: 15px 0 5px; letter-spacing: 5px; }
        .info-line { display: flex; justify-content: center; gap: 80px; font-size: 13px; margin-bottom: 5px; }
        .detail-section { margin: 15px 0; font-size: 13px; }
        .detail-section div { margin-bottom: 3px; }
        .detail-section span.label { display: inline-block; width: 100px; }
        table.ct { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 12px; }
        table.ct th, table.ct td { border: 1px solid #000; padding: 4px 6px; }
        table.ct th { background: #f0f0f0; text-align: center; font-weight: bold; }
        table.ct td.num { text-align: right; }
        .sign-section { display: flex; justify-content: space-between; margin-top: 40px; text-align: center; font-size: 12px; }
        .sign-section div { width: 30%; }
        .sign-section .title { font-weight: bold; }
        .sign-section .sub { font-style: italic; font-size: 11px; }
        .sign-section .name { margin-top: 50px; font-weight: bold; }
        @@media print { body { margin: 15px 30px; } }
    </style>
</head>
<body onload="window.print()">
    <div class="header-left">
        <strong>Công ty Cổ phần Deborah (Deborah Home)</strong><br/>
        Số 113 Điện Biên, Phường Cửa Bắc, Thành phố Nam Định, Tỉnh Nam Định<br/>
        0601164235
    </div>

    <h2>PHIẾU KẾ TOÁN</h2>
    <div class="info-line">
        <span>Ngày: @Model.NgayCT.ToString("dd/MM/yyyy")</span>
        <span>Số: <strong>@Model.SoCT</strong></span>
    </div>

    @{ decimal tongSoTien = Model.ChiTietPhieu?.Sum(c => c.SoTien) ?? 0; }
    <div class="detail-section">
        <div><span class="label">Đối tác:</span></div>
        <div><span class="label">Địa chỉ:</span></div>
        <div><span class="label">Số tiền:</span> <strong>@tongSoTien.ToString("N0") VNĐ</strong></div>
        <div><span class="label">Bằng chữ:</span> <strong style="font-style:italic"></strong></div>
        <div><span class="label">Kèm theo:</span> Chứng từ gốc</div>
    </div>

    <table class="ct">
        <thead><tr><th>Diễn giải</th><th>TK Nợ</th><th>TK Có</th><th>Tiền</th></tr></thead>
        <tbody>
            @if (Model.ChiTietPhieu != null)
            {
                @foreach (var ct in Model.ChiTietPhieu)
                {
                    <tr>
                        <td>@(ct.NoiDung ?? Model.LyDo)</td>
                        <td>@ct.TKNo</td>
                        <td>@ct.TKCo</td>
                        <td class="num">@ct.SoTien.ToString("N0")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="sign-section">
        <div><span class="title">Giám đốc</span><br/><span class="sub">(Ký, họ tên, đóng dấu)</span><br/><span class="name">WANG YONGFENG</span></div>
        <div><span class="title">Kế toán trưởng</span><br/><span class="sub">(Ký, họ tên)</span><br/><span class="name">Đặng Thị Yến</span></div>
        <div><span class="title">Người lập phiếu</span><br/><span class="sub">(Ký, họ tên)</span></div>
    </div>
</body>
</html>
